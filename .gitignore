# ── Python ────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python

# ── Virtual Environment ───────────────────────────────────────
venv/
env/
.env/
.venv/
ENV/

# ── Environment Variables ─────────────────────────────────────
.env
.env.local
.env.*.local

